{
  "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          { "type": "feat", "section": "✨ Features" },
          { "type": "fix", "section": "🐛 Bug Fixes" },
          { "type": "perf", "section": "⚡ Performance" },
          { "type": "refactor", "section": "♻️ Refactoring" },
          { "type": "docs", "section": "📝 Documentation" },
          { "type": "style", "hidden": true },
          { "type": "chore", "hidden": true },
          { "type": "ci", "hidden": true },
          { "type": "test", "hidden": true }
        ]
      },
      "header": "# Changelog\n\nAll notable changes to this project will be documented in this file.",
      "infile": "CHANGELOG.md"
    }
  },
  "git": {
    "commitMessage": "chore(release): v${version}",
    "requireBranch": "master",
    "requireCleanWorkingDir": true,
    "commit": true,
    "tag": true,
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}",
    "push": true,
    "changelog": "git log --pretty=format:\"* %s (%h)\" ${latestTag}...HEAD"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "autoGenerate": true,
    "draft": false
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:init": "git fetch --prune --prune-tags origin",
    "after:bump": "node scripts/sync-tauri-version.mjs ${version}"
  }
}